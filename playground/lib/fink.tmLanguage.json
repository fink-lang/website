{
  "name": "fink",
  "scopeName": "source.fink",
  "fileTypes": [
    "fnk"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#template_block"
    },
    {
      "include": "#fink_block"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#language_constant"
    },
    {
      "include": "#builtin_types"
    },
    {
      "include": "#wildcard"
    },
    {
      "include": "#operators_logical"
    },
    {
      "include": "#block_opener"
    },
    {
      "include": "#function_call"
    },
    {
      "include": "#operators_symbolic"
    },
    {
      "include": "#number"
    },
    {
      "include": "#regex"
    },
    {
      "include": "#string"
    },
    {
      "include": "#array"
    },
    {
      "include": "#object"
    },
    {
      "include": "#postfix_tag"
    },
    {
      "include": "#variable"
    },
    {
      "match": ",",
      "name": "meta.delimiter.comma.fink"
    },
    {
      "match": ";",
      "name": "keyword.control.semi.fink"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.fink",
          "begin": "#",
          "end": "$",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.fink"
            }
          },
          "patterns": [
            {
              "include": "#comment_sl_content"
            }
          ]
        },
        {
          "name": "comment.block.fink",
          "begin": "(?<!^)(---)",
          "end": "(---)|$",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.comment.begin.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.comment.end.fink"
            }
          },
          "patterns": [
            {
              "include": "#comment_sl_content"
            }
          ]
        },
        {
          "name": "comment.block.fink",
          "begin": "^(\\s*)(---)",
          "end": "^(\\1(---))|(---)",
          "beginCaptures": {
            "2": {
              "name": "punctuation.definition.comment.begin.fink"
            }
          },
          "endCaptures": {
            "2": {
              "name": "punctuation.definition.comment.end.fink"
            },
            "3": {
              "name": "invalid.illegal.comment.fink"
            }
          },
          "patterns": [
            {
              "include": "#comment_ml_content"
            }
          ]
        }
      ]
    },
    "comment_sl_content": {
      "patterns": [
        {
          "begin": "\\`",
          "end": "\\`",
          "contentName": "meta.embedded.block.fink",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "comment_ml_content": {
      "patterns": [
        {
          "name": "meta.embedded.block.fink",
          "begin": "(```)",
          "end": "(```)",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "template_block": {
      "patterns": [
        {
          "name": "string.tagged.block.fink.fink",
          "begin": "^(\\s*)(.*)(fink)(\")(:)\\s*$",
          "while": "(^|\\G)(\\1  |$)",
          "contentName": "string.unquoted.fink",
          "beginCaptures": {
            "2": {
              "patterns": [
                {
                  "include": "$base"
                }
              ]
            },
            "3": {
              "name": "entity.name.tag.string.fink"
            },
            "4": {
              "name": "string.unquoted.fink"
            },
            "5": {
              "name": "punctuation.definition.block.fink"
            }
          },
          "patterns": [
            {
              "include": "#string_content"
            },
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "meta.template-block.fink",
          "begin": "^(\\s*)(.*)(\")(:)\\s*$",
          "while": "(^|\\G)(\\1  |$)",
          "contentName": "string.unquoted.fink",
          "beginCaptures": {
            "2": {
              "patterns": [
                {
                  "include": "$base"
                }
              ]
            },
            "3": {
              "name": "string.unquoted.fink"
            },
            "4": {
              "name": "punctuation.definition.block.fink"
            }
          },
          "patterns": [
            {
              "include": "#string_content"
            }
          ]
        }
      ]
    },
    "fink_block": {
      "patterns": [
        {
          "name": "meta.fink-block.fink",
          "begin": "^(\\s*)(.*)(fink:)\\s*$",
          "while": "(^|\\G)\\1  ",
          "contentName": "meta.fink-block.content.fink",
          "beginCaptures": {
            "2": {
              "patterns": [
                {
                  "include": "$base"
                }
              ]
            },
            "3": {
              "name": "keyword.control.fink"
            }
          },
          "patterns": [
            {
              "include": "$base"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "(?<!\\.)\\b(import)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.fink"
            }
          }
        },
        {
          "match": "(?<!\\.)\\b(await)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.await.fink"
            }
          }
        },
        {
          "match": "(?<!\\.)\\b(yield)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.yield.fink"
            }
          }
        },
        {
          "match": "(?<!\\.)\\b(try)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.try.fink"
            }
          }
        }
      ]
    },
    "language_constant": {
      "patterns": [
        {
          "match": "(?<!\\.)\\b(true|false)\\b",
          "captures": {
            "1": {
              "name": "constant.language.boolean.$1.fink"
            }
          }
        }
      ]
    },
    "builtin_types": {
      "patterns": [
        {
          "match": "(?<!\\.)\\b(u8|u16|u32|u64|i8|i16|i64|f16|f32|f64|num|int|uint|float|dec|str)\\b",
          "captures": {
            "1": {
              "name": "support.type.fink"
            }
          }
        }
      ]
    },
    "wildcard": {
      "patterns": [
        {
          "match": "(?<![_$\u00b7\\p{L}\\p{N}])_(?![_$\u00b7\\p{L}\\p{N}])",
          "name": "keyword.control.wildcard.fink"
        }
      ]
    },
    "operators_logical": {
      "patterns": [
        {
          "match": "\\b(not\\s+in)\\b",
          "name": "keyword.operator.logical.fink"
        },
        {
          "match": "\\b(not|and|or|xor|in)\\b",
          "name": "keyword.operator.logical.fink"
        }
      ]
    },
    "operators_symbolic": {
      "patterns": [
        {
          "match": "\\|=",
          "name": "keyword.control.binding.fink"
        },
        {
          "match": "==|!=",
          "name": "keyword.operator.comparison.fink"
        },
        {
          "match": "<=|>=|><|<|>",
          "name": "keyword.operator.relational.fink"
        },
        {
          "match": "/%|\\*\\*|%%|//",
          "name": "keyword.operator.arithmetic.fink"
        },
        {
          "match": ">>>|<<<|>>|<<",
          "name": "keyword.operator.bitwise.fink"
        },
        {
          "match": "[~&^]",
          "name": "keyword.operator.bitwise.fink"
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.range.inclusive.fink"
        },
        {
          "match": "\\.\\.",
          "name": "keyword.operator.range.exclusive.fink"
        },
        {
          "match": "[-+%*/]",
          "name": "keyword.operator.arithmetic.fink"
        },
        {
          "match": "=(?!=)",
          "name": "keyword.operator.assignment.fink"
        },
        {
          "match": "\\?",
          "name": "keyword.control.partial.fink"
        },
        {
          "match": "(?<!\\.)\\.(?!\\.)([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)\\b(?![:(])",
          "captures": {
            "0": {
              "name": "punctuation.accessor.fink"
            },
            "1": {
              "name": "variable.other.property.fink"
            }
          }
        }
      ]
    },
    "block_opener": {
      "patterns": [
        {
          "begin": "\\b(fn|match)\\b",
          "end": "(:)",
          "contentName": "meta.block.parameters.fink",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.block.$1.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.block.fink"
            }
          },
          "patterns": [
            {
              "include": "$base"
            }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "match": "(0)(x)_?[0-9a-fA-F][0-9a-fA-F_]*([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?",
          "name": "constant.numeric.hex.fink",
          "captures": {
            "1": {
              "name": "constant.numeric.hex.fink"
            },
            "2": {
              "name": "constant.character.escape.fink"
            },
            "3": {
              "name": "entity.name.tag.numeric.fink"
            }
          }
        },
        {
          "match": "(0)(o)_?[0-7][0-7_]*([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?",
          "name": "constant.numeric.octal.fink",
          "captures": {
            "1": {
              "name": "constant.numeric.octal.fink"
            },
            "2": {
              "name": "constant.character.escape.fink"
            },
            "3": {
              "name": "entity.name.tag.numeric.fink"
            }
          }
        },
        {
          "match": "(0)(b)_?[01][01_]*([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?",
          "name": "constant.numeric.binary.fink",
          "captures": {
            "1": {
              "name": "constant.numeric.binary.fink"
            },
            "2": {
              "name": "constant.character.escape.fink"
            },
            "3": {
              "name": "entity.name.tag.numeric.fink"
            }
          }
        },
        {
          "match": "[0-9][0-9_]*\\.[0-9][0-9_]*((d)[+\\-]?[0-9][0-9_]*|(d))([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?",
          "name": "constant.numeric.decimal.fink",
          "captures": {
            "2": {
              "name": "constant.character.escape.fink"
            },
            "3": {
              "name": "constant.character.escape.fink"
            },
            "4": {
              "name": "entity.name.tag.numeric.fink"
            }
          }
        },
        {
          "match": "[0-9][0-9_]*\\.[0-9][0-9_]*((e)[+\\-]?[0-9][0-9_]*)?([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?",
          "name": "constant.numeric.float.fink",
          "captures": {
            "2": {
              "name": "constant.character.escape.fink"
            },
            "3": {
              "name": "entity.name.tag.numeric.fink"
            }
          }
        },
        {
          "match": "[0-9][0-9_]*([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?",
          "name": "constant.numeric.integer.fink",
          "captures": {
            "1": {
              "name": "entity.name.tag.numeric.fink"
            }
          }
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "name": "string.regexp.fink",
          "begin": "(rx)(')",
          "end": "(\\2)",
          "beginCaptures": {
            "1": {
              "name": "keyword.other.regex-prefix.fink"
            },
            "2": {
              "name": "punctuation.definition.regexp.begin.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.regexp.end.fink"
            }
          },
          "patterns": [
            {
              "include": "source.regexp.fink"
            }
          ]
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.tagged.css.fink",
          "begin": "\\b(css)(')",
          "end": "(\\2)",
          "contentName": "meta.embedded.block.markdown.css.fink",
          "beginCaptures": {
            "1": {
              "name": "entity.name.tag.string.fink"
            },
            "2": {
              "name": "punctuation.definition.string.begin.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.fink"
            }
          },
          "patterns": [
            {
              "include": "#string_content"
            },
            {
              "include": "source.css"
            }
          ]
        },
        {
          "name": "string.tagged.sql.fink",
          "begin": "\\b(sql)(')",
          "end": "(\\2)",
          "contentName": "meta.embedded.block.markdown.sql.fink",
          "beginCaptures": {
            "1": {
              "name": "entity.name.tag.string.fink"
            },
            "2": {
              "name": "punctuation.definition.string.begin.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.fink"
            }
          },
          "patterns": [
            {
              "include": "#string_content"
            },
            {
              "include": "source.sql"
            }
          ]
        },
        {
          "name": "string.tagged.fink.fink",
          "begin": "\\b(fink)(')",
          "end": "(\\2)",
          "contentName": "meta.embedded.block.markdown.fink.fink",
          "beginCaptures": {
            "1": {
              "name": "entity.name.tag.string.fink"
            },
            "2": {
              "name": "punctuation.definition.string.begin.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.fink"
            }
          },
          "patterns": [
            {
              "include": "#string_content"
            },
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "string.quoted.fink",
          "begin": "([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)?(')",
          "end": "(\\2)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.tag.string.fink"
            },
            "2": {
              "name": "punctuation.definition.string.begin.fink"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.fink"
            }
          },
          "patterns": [
            {
              "include": "#string_content"
            }
          ]
        }
      ]
    },
    "string_content": {
      "patterns": [
        {
          "name": "meta.interpolation.fink",
          "begin": "\\${",
          "end": "}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.fink"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.fink"
            }
          },
          "patterns": [
            {
              "include": "$base"
            }
          ]
        },
        {
          "name": "constant.character.escape.fink",
          "match": "\\\\[\\\\'nrtbfv0]"
        },
        {
          "name": "constant.character.escape.fink",
          "match": "\\\\\\$\\{"
        },
        {
          "name": "constant.character.escape.fink",
          "match": "\\\\u(\\{[0-9a-fA-F][0-9a-fA-F_]*\\}|[0-9a-fA-F][0-9a-fA-F_]*)"
        },
        {
          "name": "constant.character.escape.fink",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "name": "constant.character.escape.fink",
          "match": "\\\\b[01]+"
        },
        {
          "name": "invalid.illegal.escape.fink",
          "match": "\\\\."
        }
      ]
    },
    "array": {
      "name": "meta.sequence.fink",
      "begin": "\\[",
      "end": "\\]",
      "patterns": [
        {
          "include": "$base"
        }
      ]
    },
    "obj_delimited": {
      "name": "meta.record.fink",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [
        {
          "name": "meta.record.prop.shorthand.fink",
          "match": "([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)\\s*(?=,|\\}|$)",
          "captures": {
            "1": {
              "name": "variable.other.constant.fink"
            }
          }
        },
        {
          "name": "meta.record.prop.fink",
          "begin": "([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)\\s*(?=:)",
          "end": "(?=,|\\}|$)",
          "beginCaptures": {
            "1": {
              "name": "variable.other.property.fink"
            }
          },
          "patterns": [
            {
              "include": "$base"
            }
          ]
        },
        {
          "name": "meta.record.prop.default.fink",
          "begin": "([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)\\s*(?==)",
          "end": "(?=,|\\}|$)",
          "beginCaptures": {
            "1": {
              "name": "variable.other.constant.fink"
            }
          },
          "patterns": [
            {
              "include": "$base"
            }
          ]
        },
        {
          "name": "meta.record.computed-key.fink",
          "begin": "(?=\\()",
          "end": "(?=,|\\}|$)",
          "patterns": [
            {
              "begin": "\\(",
              "end": "\\)\\s*(?=:)",
              "patterns": [
                {
                  "include": "$base"
                }
              ]
            },
            {
              "begin": ":",
              "end": "(?=,|\\}|$)",
              "patterns": [
                {
                  "include": "$base"
                }
              ]
            }
          ]
        },
        {
          "name": "meta.record.spread.fink",
          "begin": "\\.\\.",
          "end": "(?=,|\\}|$)",
          "beginCaptures": {
            "0": {
              "name": "keyword.operator.spread.fink"
            }
          },
          "patterns": [
            {
              "include": "$base"
            }
          ]
        },
        {
          "include": "$base"
        }
      ]
    },
    "object": {
      "patterns": [
        {
          "include": "#obj_delimited"
        }
      ]
    },
    "postfix_tag": {
      "patterns": [
        {
          "match": "(?<=\\)|\\])([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)(?![_$\u00b7\\p{L}\\p{N}])",
          "captures": {
            "1": {
              "name": "entity.name.tag.postfix.fink"
            }
          }
        }
      ]
    },
    "function_call": {
      "patterns": [
        {
          "match": "(\\|(?!=))\\s*([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)(?![_$\u00b7\\p{L}\\p{N}])",
          "captures": {
            "1": {
              "name": "keyword.control.pipe.fink"
            },
            "2": {
              "name": "entity.name.function.fink"
            }
          }
        },
        {
          "match": "(?!\\b(?:fn|match|import|await|yield|try|not|and|or|xor|in)\\b)([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)(?=\\s+[_$\u00b7\\p{L}0-9'\\(\\[\\{])",
          "captures": {
            "1": {
              "name": "entity.name.function.fink"
            }
          }
        },
        {
          "match": "\\|(?!=)",
          "name": "keyword.control.pipe.fink"
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "match": "(?<![_$\u00b7\\p{L}])([_$\u00b7\\p{L}][-_$\u00b7\\p{L}\\p{N}]*)(?![_$\u00b7\\p{L}\\p{N}])",
          "captures": {
            "1": {
              "name": "variable.other.constant.fink"
            }
          }
        }
      ]
    }
  }
}